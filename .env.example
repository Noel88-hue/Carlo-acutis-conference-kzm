# Copy this file to .env locally if you want to test production-like settings.
# On Railway, set these as actual Environment Variables in the dashboard instead.

SECRET_KEY=replace-with-a-long-random-string
DEBUG=False

# Railway auto-injects DATABASE_URL when you attach a PostgreSQL plugin —
# you don't need to set this yourself.
DATABASE_URL=

# Get this from cloudinary.com after creating a free account —
# Dashboard page shows it as "API Environment variable".
CLOUDINARY_URL=cloudinary://<api_key>:<api_secret>@<cloud_name>
